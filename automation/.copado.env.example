# Copado Robotic Testing executor config — copy to `.copado.env` and fill in.
# `.copado.env` is gitignored; never commit real secrets.

# --- Required -------------------------------------------------------------------
# Personal Access Key (CRT). Sent as the X-Authorization header.
COPADO_PAT=

# Region API host (the api.* host, not the app host):
#   US: https://api.robotic.copado.com
#   EU: https://api.eu-robotic.copado.com
#   AU: https://api.au-robotic.copado.com
COPADO_BASE_URL=https://api.au-robotic.copado.com

# Project id and Job id. Find the job id with `discover`.
# (This repo: project 12325, job 21321 = "Service".)
COPADO_PROJECT_ID=12325
COPADO_JOB_ID=21321

# --- Auth header (default is correct for the region API) -----------------------
COPADO_AUTH_HEADER=X-Authorization

# --- Polling -------------------------------------------------------------------
POLL_INTERVAL=15
POLL_TIMEOUT=1800
